# App
NODE_ENV=development
ALLOW_MOCK_DATA=false

# PostgreSQL
# Use SSL in production when the database is not on the same private host/network.
POSTGRES_DB=bilhas
POSTGRES_USER=bilhas_app
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_PORT=5432
DATABASE_URL=postgres://bilhas_app:change_me_to_a_strong_password@127.0.0.1:5432/bilhas
DATABASE_SSL=false

# Future services
OPENAI_API_KEY=
FOOTBALL_API_KEY=
